# ─────────────────────────────────────────────
# GreenCoin — Environment Configuration
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://greencoin:greencoin_secret@localhost:5432/greencoin

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────
JWT_SECRET=change_me_to_a_random_64_char_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Demo Mode ─────────────────────────────────
# Set to True to use mock API responses (no real keys needed)
DEMO_MODE=True

# ── Google APIs ───────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here

# ── Claude AI ─────────────────────────────────
CLAUDE_API_KEY=your_claude_api_key_here

# ── Mapbox ────────────────────────────────────
MAPBOX_TOKEN=your_mapbox_public_token_here

# ── App Settings ──────────────────────────────
APP_NAME=GreenCoin
APP_VERSION=1.0.0
DEBUG=True
BACKEND_PORT=8000

# ── Credit Economy ────────────────────────────
CREDIT_TO_INR=50
CREDITS_PER_TONNE=100

# ── Frontend URLs (for CORS) ──────────────────
USER_FRONTEND_URL=http://localhost:5173
CORP_FRONTEND_URL=http://localhost:5174
